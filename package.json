{
  "name": "runner",
  "version": "0.0.3",
  "private": true,
  "description": "Claude Code workbench: multi-terminal + git in one window",
  "author": "sangji.park",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "RUNNER_DATA_DIR=$HOME/.runner-dev env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "package": "electron-vite build && electron-builder",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:dir": "electron-vite build && electron-builder --dir",
    "gen:icon": "node scripts/gen-icon.mjs",
    "release": "npm version patch -m \"release: v%s\" && git push --follow-tags",
    "rebuild": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.parksangji.runner",
    "productName": "Runner",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "parksangji",
        "repo": "runner"
      }
    ],
    "releaseInfo": {
      "releaseNotesFile": "build/release-notes.md"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^3.6.0",
    "diff": "^5.2.0",
    "dockview-react": "^2.0.0",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hotkeys-hook": "^4.5.0",
    "simple-git": "^3.25.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/diff": "^5.2.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.6.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^5.3.4",
    "vitest": "^2.0.5"
  }
}
